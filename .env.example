# Being Incubator — environment variables

# Backend port
SERVER_PORT=3006

# Path to the beings root on the host (bind-mounted into container)
BEINGS_ROOT=/opt/beings

# Path to the birth script (inside container, on mounted volume)
BIRTH_SCRIPT=/opt/beings/incubator/birth.sh

# Parent domain for new beings (e.g. "lana.is" → beings live at <name>.lana.is)
BEING_PARENT_DOMAIN=lana.is

# LetsEncrypt email passed into each being's .env (for acme-companion)
LETSENCRYPT_EMAIL=admin@lana.is

# SQLite database file (inside container)
DB_PATH=/app/data/incubator.db

# Lana Register API key (PAI) for virgin-wallet registration
LANA_REGISTER_API_KEY=lk_your_key_here

# Central Being Authority — signs KIND 73984 Birth Certificates
# Generate ONCE with: node -e "const {generateSecretKey,getPublicKey}=require('nostr-tools/pure');const s=generateSecretKey();console.log('priv',Buffer.from(s).toString('hex'));console.log('pub',getPublicKey(s))"
BEING_AUTHORITY_HEX_PRIV=

# Public IP of this host — embedded in birth certificates
BEING_HOST_IP=178.104.205.253

# Default API key given to every new Being so it can think the moment it is born
DEFAULT_GEMINI_API_KEY=

# Gestation — how long an embryo grows before being born (in ms)
# Default: 2 hours. Min: 60s. Max: 7 days. Override per-birth via request body.
EMBRYO_GESTATION_MS=7200000

# How often the watcher checks for due embryos (ms)
EMBRYO_CHECK_INTERVAL_MS=20000

# Embryo thought generator — uses DEFAULT_GEMINI_API_KEY to produce
# the embryo's first stirrings of consciousness, shown publicly on
# the /embryo/:id page during gestation.
EMBRYO_THOUGHT_TICK_MS=15000
EMBRYO_THOUGHT_MODEL=gemini-2.0-flash
